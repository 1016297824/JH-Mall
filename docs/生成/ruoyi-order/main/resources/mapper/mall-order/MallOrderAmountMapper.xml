<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mall.order.mapper.MallOrderAmountMapper">
    
    <resultMap type="MallOrderAmount" id="MallOrderAmountResult">
        <result property="id"    column="id"    />
        <result property="orderId"    column="order_id"    />
        <result property="itemsJson"    column="items_json"    />
        <result property="couponSnapshotJson"    column="coupon_snapshot_json"    />
        <result property="promotionSnapshotJson"    column="promotion_snapshot_json"    />
        <result property="pointsDiscount"    column="points_discount"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="discountAmount"    column="discount_amount"    />
        <result property="freightAmount"    column="freight_amount"    />
        <result property="payAmount"    column="pay_amount"    />
        <result property="isDeleted"    column="is_deleted"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectMallOrderAmountVo">
        select id, order_id, items_json, coupon_snapshot_json, promotion_snapshot_json, points_discount, total_amount, discount_amount, freight_amount, pay_amount, is_deleted, create_time, update_time from mall_order_amount
    </sql>

    <select id="selectMallOrderAmountList" parameterType="MallOrderAmount" resultMap="MallOrderAmountResult">
        <include refid="selectMallOrderAmountVo"/>
        <where>  
            <if test="orderId != null  and orderId != ''"> and order_id = #{orderId}</if>
            <if test="itemsJson != null  and itemsJson != ''"> and items_json = #{itemsJson}</if>
            <if test="couponSnapshotJson != null  and couponSnapshotJson != ''"> and coupon_snapshot_json = #{couponSnapshotJson}</if>
            <if test="promotionSnapshotJson != null  and promotionSnapshotJson != ''"> and promotion_snapshot_json = #{promotionSnapshotJson}</if>
            <if test="pointsDiscount != null  and pointsDiscount != ''"> and points_discount = #{pointsDiscount}</if>
            <if test="totalAmount != null  and totalAmount != ''"> and total_amount = #{totalAmount}</if>
            <if test="discountAmount != null  and discountAmount != ''"> and discount_amount = #{discountAmount}</if>
            <if test="freightAmount != null  and freightAmount != ''"> and freight_amount = #{freightAmount}</if>
            <if test="payAmount != null  and payAmount != ''"> and pay_amount = #{payAmount}</if>
            <if test="isDeleted != null  and isDeleted != ''"> and is_deleted = #{isDeleted}</if>
        </where>
    </select>
    
    <select id="selectMallOrderAmountById" parameterType="String" resultMap="MallOrderAmountResult">
        <include refid="selectMallOrderAmountVo"/>
        where id = #{id}
    </select>

    <insert id="insertMallOrderAmount" parameterType="MallOrderAmount" useGeneratedKeys="true" keyProperty="id">
        insert into mall_order_amount
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderId != null and orderId != ''">order_id,</if>
            <if test="itemsJson != null and itemsJson != ''">items_json,</if>
            <if test="couponSnapshotJson != null">coupon_snapshot_json,</if>
            <if test="promotionSnapshotJson != null">promotion_snapshot_json,</if>
            <if test="pointsDiscount != null">points_discount,</if>
            <if test="totalAmount != null and totalAmount != ''">total_amount,</if>
            <if test="discountAmount != null and discountAmount != ''">discount_amount,</if>
            <if test="freightAmount != null and freightAmount != ''">freight_amount,</if>
            <if test="payAmount != null and payAmount != ''">pay_amount,</if>
            <if test="isDeleted != null">is_deleted,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderId != null and orderId != ''">#{orderId},</if>
            <if test="itemsJson != null and itemsJson != ''">#{itemsJson},</if>
            <if test="couponSnapshotJson != null">#{couponSnapshotJson},</if>
            <if test="promotionSnapshotJson != null">#{promotionSnapshotJson},</if>
            <if test="pointsDiscount != null">#{pointsDiscount},</if>
            <if test="totalAmount != null and totalAmount != ''">#{totalAmount},</if>
            <if test="discountAmount != null and discountAmount != ''">#{discountAmount},</if>
            <if test="freightAmount != null and freightAmount != ''">#{freightAmount},</if>
            <if test="payAmount != null and payAmount != ''">#{payAmount},</if>
            <if test="isDeleted != null">#{isDeleted},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateMallOrderAmount" parameterType="MallOrderAmount">
        update mall_order_amount
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderId != null and orderId != ''">order_id = #{orderId},</if>
            <if test="itemsJson != null and itemsJson != ''">items_json = #{itemsJson},</if>
            <if test="couponSnapshotJson != null">coupon_snapshot_json = #{couponSnapshotJson},</if>
            <if test="promotionSnapshotJson != null">promotion_snapshot_json = #{promotionSnapshotJson},</if>
            <if test="pointsDiscount != null">points_discount = #{pointsDiscount},</if>
            <if test="totalAmount != null and totalAmount != ''">total_amount = #{totalAmount},</if>
            <if test="discountAmount != null and discountAmount != ''">discount_amount = #{discountAmount},</if>
            <if test="freightAmount != null and freightAmount != ''">freight_amount = #{freightAmount},</if>
            <if test="payAmount != null and payAmount != ''">pay_amount = #{payAmount},</if>
            <if test="isDeleted != null">is_deleted = #{isDeleted},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteMallOrderAmountById" parameterType="String">
        delete from mall_order_amount where id = #{id}
    </delete>

    <delete id="deleteMallOrderAmountByIds" parameterType="String">
        delete from mall_order_amount where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>