<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mall.user.mapper.MallUserPointsAccountMapper">
    
    <resultMap type="MallUserPointsAccount" id="MallUserPointsAccountResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="totalPoints"    column="total_points"    />
        <result property="availablePoints"    column="available_points"    />
        <result property="usedPoints"    column="used_points"    />
        <result property="expiredPoints"    column="expired_points"    />
        <result property="version"    column="version"    />
        <result property="isDeleted"    column="is_deleted"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectMallUserPointsAccountVo">
        select id, user_id, total_points, available_points, used_points, expired_points, version, is_deleted, create_time, update_time from mall_user_points_account
    </sql>

    <select id="selectMallUserPointsAccountList" parameterType="MallUserPointsAccount" resultMap="MallUserPointsAccountResult">
        <include refid="selectMallUserPointsAccountVo"/>
        <where>  
            <if test="userId != null  and userId != ''"> and user_id = #{userId}</if>
            <if test="totalPoints != null  and totalPoints != ''"> and total_points = #{totalPoints}</if>
            <if test="availablePoints != null  and availablePoints != ''"> and available_points = #{availablePoints}</if>
            <if test="usedPoints != null  and usedPoints != ''"> and used_points = #{usedPoints}</if>
            <if test="expiredPoints != null  and expiredPoints != ''"> and expired_points = #{expiredPoints}</if>
            <if test="isDeleted != null  and isDeleted != ''"> and is_deleted = #{isDeleted}</if>
        </where>
    </select>
    
    <select id="selectMallUserPointsAccountById" parameterType="String" resultMap="MallUserPointsAccountResult">
        <include refid="selectMallUserPointsAccountVo"/>
        where id = #{id}
    </select>

    <insert id="insertMallUserPointsAccount" parameterType="MallUserPointsAccount" useGeneratedKeys="true" keyProperty="id">
        insert into mall_user_points_account
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null and userId != ''">user_id,</if>
            <if test="totalPoints != null">total_points,</if>
            <if test="availablePoints != null">available_points,</if>
            <if test="usedPoints != null">used_points,</if>
            <if test="expiredPoints != null">expired_points,</if>
            <if test="isDeleted != null">is_deleted,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null and userId != ''">#{userId},</if>
            <if test="totalPoints != null">#{totalPoints},</if>
            <if test="availablePoints != null">#{availablePoints},</if>
            <if test="usedPoints != null">#{usedPoints},</if>
            <if test="expiredPoints != null">#{expiredPoints},</if>
            <if test="isDeleted != null">#{isDeleted},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateMallUserPointsAccount" parameterType="MallUserPointsAccount">
        update mall_user_points_account
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null and userId != ''">user_id = #{userId},</if>
            <if test="totalPoints != null">total_points = #{totalPoints},</if>
            <if test="availablePoints != null">available_points = #{availablePoints},</if>
            <if test="usedPoints != null">used_points = #{usedPoints},</if>
            <if test="expiredPoints != null">expired_points = #{expiredPoints},</if>
            <if test="isDeleted != null">is_deleted = #{isDeleted},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteMallUserPointsAccountById" parameterType="String">
        delete from mall_user_points_account where id = #{id}
    </delete>

    <delete id="deleteMallUserPointsAccountByIds" parameterType="String">
        delete from mall_user_points_account where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>