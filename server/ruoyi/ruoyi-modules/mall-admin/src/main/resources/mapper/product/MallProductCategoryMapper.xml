<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mall.product.mapper.MallProductCategoryMapper">
    
    <resultMap type="MallProductCategory" id="MallProductCategoryResult">
        <result property="id"    column="id"    />
        <result property="parentId"    column="parent_id"    />
        <result property="name"    column="name"    />
        <result property="level"    column="level"    />
        <result property="icon"    column="icon"    />
        <result property="sortOrder"    column="sort_order"    />
        <result property="isVisible"    column="is_visible"    />
        <result property="path"    column="path"    />
        <result property="isDeleted"    column="is_deleted"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectMallProductCategoryVo">
        select id, parent_id, name, level, icon, sort_order, is_visible, path, is_deleted, create_time, update_time from mall_product_category
    </sql>

    <select id="selectMallProductCategoryList" parameterType="MallProductCategory" resultMap="MallProductCategoryResult">
        <include refid="selectMallProductCategoryVo"/>
        <where>  
            <if test="parentId != null  and parentId != ''"> and parent_id = #{parentId}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="level != null  and level != ''"> and level = #{level}</if>
            <if test="icon != null  and icon != ''"> and icon = #{icon}</if>
            <if test="sortOrder != null  and sortOrder != ''"> and sort_order = #{sortOrder}</if>
            <if test="isVisible != null  and isVisible != ''"> and is_visible = #{isVisible}</if>
            <if test="path != null  and path != ''"> and path = #{path}</if>
            <if test="isDeleted != null  and isDeleted != ''"> and is_deleted = #{isDeleted}</if>
        </where>
    </select>
    
    <select id="selectMallProductCategoryById" parameterType="String" resultMap="MallProductCategoryResult">
        <include refid="selectMallProductCategoryVo"/>
        where id = #{id}
    </select>

    <insert id="insertMallProductCategory" parameterType="MallProductCategory" useGeneratedKeys="true" keyProperty="id">
        insert into mall_product_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="parentId != null and parentId != ''">parent_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="level != null and level != ''">level,</if>
            <if test="icon != null">icon,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="isVisible != null">is_visible,</if>
            <if test="path != null">path,</if>
            <if test="isDeleted != null">is_deleted,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="parentId != null and parentId != ''">#{parentId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="level != null and level != ''">#{level},</if>
            <if test="icon != null">#{icon},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="isVisible != null">#{isVisible},</if>
            <if test="path != null">#{path},</if>
            <if test="isDeleted != null">#{isDeleted},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateMallProductCategory" parameterType="MallProductCategory">
        update mall_product_category
        <trim prefix="SET" suffixOverrides=",">
            <if test="parentId != null and parentId != ''">parent_id = #{parentId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="level != null and level != ''">level = #{level},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="isVisible != null">is_visible = #{isVisible},</if>
            <if test="path != null">path = #{path},</if>
            <if test="isDeleted != null">is_deleted = #{isDeleted},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteMallProductCategoryById" parameterType="String">
        delete from mall_product_category where id = #{id}
    </delete>

    <delete id="deleteMallProductCategoryByIds" parameterType="String">
        delete from mall_product_category where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>