    <sql id="selectMallUserVo">
        select id, phone, phone_hash, password, nickname, avatar, email, email_hash, gender, birthday, user_status, register_type, register_ip, register_time, last_login_time, last_login_ip, is_privacy_agreed, privacy_agreed_time, wechat_openid, wechat_unionid, is_deleted, create_by, update_by, create_time, update_time, version, remark from mall_user
    </sql>

    <select id="selectMallUserList" parameterType="MallUser" resultMap="MallUserResult">
        <include refid="selectMallUserVo"/>
        <where>  
            <if test="phone != null  and phone != ''"> and phone = #{phone}</if>
            <if test="phoneHash != null  and phoneHash != ''"> and phone_hash = #{phoneHash}</if>
            <if test="password != null  and password != ''"> and password = #{password}</if>
            <if test="nickname != null  and nickname != ''"> and nickname like concat('%', #{nickname}, '%')</if>
            <if test="avatar != null  and avatar != ''"> and avatar = #{avatar}</if>
            <if test="email != null  and email != ''"> and email = #{email}</if>
            <if test="emailHash != null  and emailHash != ''"> and email_hash = #{emailHash}</if>
