            <if test="registerType != null  and registerType != ''"> and register_type = #{registerType}</if>
            <if test="registerIp != null  and registerIp != ''"> and register_ip = #{registerIp}</if>
            <if test="registerTime != null "> and register_time = #{registerTime}</if>
            <if test="lastLoginTime != null "> and last_login_time = #{lastLoginTime}</if>
            <if test="lastLoginIp != null  and lastLoginIp != ''"> and last_login_ip = #{lastLoginIp}</if>
            <if test="isPrivacyAgreed != null  and isPrivacyAgreed != ''"> and is_privacy_agreed = #{isPrivacyAgreed}</if>
            <if test="privacyAgreedTime != null "> and privacy_agreed_time = #{privacyAgreedTime}</if>
            <if test="wechatOpenid != null  and wechatOpenid != ''"> and wechat_openid = #{wechatOpenid}</if>
            <if test="wechatUnionid != null  and wechatUnionid != ''"> and wechat_unionid = #{wechatUnionid}</if>
            <if test="isDeleted != null  and isDeleted != ''"> and is_deleted = #{isDeleted}</if>
            <if test="version != null  and version != ''"> and version = #{version}</if>
        </where>
    </select>
    
    <select id="selectMallUserById" parameterType="String" resultMap="MallUserResult">
