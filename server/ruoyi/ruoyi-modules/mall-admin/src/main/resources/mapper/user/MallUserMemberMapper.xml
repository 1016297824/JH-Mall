<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mall.admin.user.mapper.MallUserMemberMapper">
    
    <resultMap type="MallUserMember" id="MallUserMemberResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="levelId"    column="level_id"    />
        <result property="growth"    column="growth"    />
        <result property="totalGrowth"    column="total_growth"    />
        <result property="levelStartTime"    column="level_start_time"    />
        <result property="levelEndTime"    column="level_end_time"    />
        <result property="becomeTime"    column="become_time"    />
        <result property="isDeleted"    column="is_deleted"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectMallUserMemberVo">
        select id, user_id, level_id, growth, total_growth, level_start_time, level_end_time, become_time, is_deleted, create_time, update_time from mall_user_member
    </sql>

    <select id="selectMallUserMemberList" parameterType="MallUserMember" resultMap="MallUserMemberResult">
        <include refid="selectMallUserMemberVo"/>
        <where>  
            <if test="userId != null  and userId != ''"> and user_id = #{userId}</if>
            <if test="levelId != null  and levelId != ''"> and level_id = #{levelId}</if>
            <if test="growth != null  and growth != ''"> and growth = #{growth}</if>
            <if test="totalGrowth != null  and totalGrowth != ''"> and total_growth = #{totalGrowth}</if>
            <if test="levelStartTime != null "> and level_start_time = #{levelStartTime}</if>
            <if test="levelEndTime != null "> and level_end_time = #{levelEndTime}</if>
            <if test="becomeTime != null "> and become_time = #{becomeTime}</if>
            <if test="isDeleted != null  and isDeleted != ''"> and is_deleted = #{isDeleted}</if>
        </where>
    </select>
    
    <select id="selectMallUserMemberById" parameterType="String" resultMap="MallUserMemberResult">
        <include refid="selectMallUserMemberVo"/>
        where id = #{id}
    </select>

    <insert id="insertMallUserMember" parameterType="MallUserMember" useGeneratedKeys="true" keyProperty="id">
        insert into mall_user_member
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null and userId != ''">user_id,</if>
            <if test="levelId != null">level_id,</if>
            <if test="growth != null">growth,</if>
            <if test="totalGrowth != null">total_growth,</if>
            <if test="levelStartTime != null">level_start_time,</if>
            <if test="levelEndTime != null">level_end_time,</if>
            <if test="becomeTime != null">become_time,</if>
            <if test="isDeleted != null">is_deleted,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null and userId != ''">#{userId},</if>
            <if test="levelId != null">#{levelId},</if>
            <if test="growth != null">#{growth},</if>
            <if test="totalGrowth != null">#{totalGrowth},</if>
            <if test="levelStartTime != null">#{levelStartTime},</if>
            <if test="levelEndTime != null">#{levelEndTime},</if>
            <if test="becomeTime != null">#{becomeTime},</if>
            <if test="isDeleted != null">#{isDeleted},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateMallUserMember" parameterType="MallUserMember">
        update mall_user_member
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null and userId != ''">user_id = #{userId},</if>
            <if test="levelId != null">level_id = #{levelId},</if>
            <if test="growth != null">growth = #{growth},</if>
            <if test="totalGrowth != null">total_growth = #{totalGrowth},</if>
            <if test="levelStartTime != null">level_start_time = #{levelStartTime},</if>
            <if test="levelEndTime != null">level_end_time = #{levelEndTime},</if>
            <if test="becomeTime != null">become_time = #{becomeTime},</if>
            <if test="isDeleted != null">is_deleted = #{isDeleted},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteMallUserMemberById" parameterType="String">
        delete from mall_user_member where id = #{id}
    </delete>

    <delete id="deleteMallUserMemberByIds" parameterType="String">
        delete from mall_user_member where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>